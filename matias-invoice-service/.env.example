# Puerto del servicio (debe coincidir con INVOICE_SERVICE_URL en Vendure, ej. http://localhost:3010/api)
PORT=3010
NODE_ENV=development

MATIAS_API_URL=https://api-v2.matias-api.com/api/ubl2.1
MATIAS_EMAIL=
MATIAS_PASSWORD=

# API Key que el backend Vendure envía en X-API-Key (misma que INVOICE_SERVICE_API_KEY en shop)
VENDURE_SERVICE_API_KEY=

LOG_LEVEL=info

# --- Base de datos SOLO del microservicio (no uses el DATABASE_URL de Vendure/shop) ---
# Crea un Postgres aparte (Railway: segundo servicio PostgreSQL) y pega la URL aquí.
INVOICE_SERVICE_DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Railway / SSL: a veces basta con ?sslmode=require en la URL; si falla, prueba:
# INVOICE_SERVICE_DB_SSL=true
